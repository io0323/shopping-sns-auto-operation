# 楽天ウェブサービス
RAKUTEN_APP_ID=
RAKUTEN_AFFILIATE_ID=

# Anthropic
ANTHROPIC_API_KEY=

# コスト上限(円/月)
MONTHLY_LLM_BUDGET_JPY=3000

# DB(SQLAlchemy接続文字列)
DATABASE_URL=sqlite:///./data.db

# 役割別モデル(ハードコード禁止。ここで切替)
MODEL_GENERATOR=claude-sonnet-5
MODEL_EVALUATOR=claude-haiku-4-5
MODEL_LEARNING=claude-sonnet-5

# コスト概算用の為替レート(USD->JPY)
USD_JPY_RATE=150.0

# パイプライン通知用Slack Webhook(任意。未設定なら送信しない)
SLACK_WEBHOOK_URL=
